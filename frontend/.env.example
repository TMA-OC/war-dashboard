# Database (not needed for frontend, but NextAuth may reference)
DATABASE_URL=postgresql://...

# Google OAuth
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret

# NextAuth
NEXTAUTH_SECRET=your-random-secret
NEXTAUTH_URL=http://localhost:3000

# Backend API
NEXT_PUBLIC_API_URL=https://war-dashboard-api.the-models-aigency.workers.dev

# Optional: Mapbox token (falls back to Leaflet/OSM)
NEXT_PUBLIC_MAPBOX_TOKEN=
