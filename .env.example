# =============================================================================
# War Dashboard — Environment Variables Reference
# =============================================================================
# Copy this file to .env and fill in the values.
# NEVER commit .env to version control.

# --- Database -----------------------------------------------------------
# Supabase or Neon Postgres connection string (required)
DATABASE_URL=postgresql://user:password@host:5432/dbname?sslmode=require

# --- Auth ---------------------------------------------------------------
# Random 32+ char secret for JWT signing
JWT_SECRET=change-me-to-a-random-secret

# --- Cloudflare ---------------------------------------------------------
# Required for CI/CD deployments; add these as GitHub Actions secrets:
# TODO: needs CLOUDFLARE_API_TOKEN and CLOUDFLARE_ACCOUNT_ID secrets in GitHub
CLOUDFLARE_API_TOKEN=your-cloudflare-api-token
CLOUDFLARE_ACCOUNT_ID=your-cloudflare-account-id

# Cloudflare Pages project name (must match the name in your CF dashboard)
CF_PAGES_PROJECT_NAME=war-dashboard

# --- Frontend (Vite) ----------------------------------------------------
# API base URL used during build — set in GitHub secrets per environment
VITE_API_URL=http://localhost:8787
VITE_API_URL_PREVIEW=https://war-dashboard-api-preview.workers.dev
VITE_API_URL_PROD=https://war-dashboard-api.workers.dev

# --- Optional / Future --------------------------------------------------
# OpenAI API key for geocoding / classification assistance
OPENAI_API_KEY=
