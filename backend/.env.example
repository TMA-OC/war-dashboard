# Database
DATABASE_URL=postgresql://user:password@localhost:5432/wardash

# Auth
JWT_SECRET=change-me-to-a-long-random-secret-min-32-chars

# Google OAuth
GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-google-client-secret

# Frontend URL (used in OAuth callback redirects)
# Development: http://localhost:5173
# Production: https://war-dashboard.pages.dev
FRONTEND_URL=http://localhost:5173

# Maps
MAPBOX_TOKEN=pk.your_mapbox_token_here

# Optional
OPENAI_API_KEY=sk-your-key-for-geocoding-assistance
